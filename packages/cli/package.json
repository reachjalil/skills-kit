{
  "name": "@skills-kit/cli",
  "version": "1.0.2",
  "description": "Repo-local skill switchboard for local agent skill libraries.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Jalil Laaraichi (@reachjalil)",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skills-kit": "dist/cli.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "README.md",
    "llms.txt",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "SAFETY_MODEL.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && bun build ./src/cli.ts ./src/index.ts --packages=external --target=node --outdir=dist && chmod +x dist/cli.js && tsc -p tsconfig.build.json",
    "audit:package": "node ./scripts/audit-package.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:fast": "tsc -p tsconfig.json --noEmit",
    "dev": "bun run ./src/cli.ts",
    "lint": "pnpm exec biome check src scripts",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run quality",
    "publish:dry-run": "node ./scripts/publish-dry-run.mjs",
    "quality": "pnpm run lint && pnpm run check && pnpm run test && pnpm run build && pnpm run smoke:pack && pnpm run audit:package",
    "smoke:pack": "node ./scripts/smoke-pack.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reachjalil/skills-kit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/reachjalil/skills-kit/issues"
  },
  "homepage": "https://skills-kit.sh",
  "dependencies": {
    "@clack/core": "^1.3.0",
    "@clack/prompts": "^1.3.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "agent-skills",
    "ai-agent-tools",
    "ai-agents",
    "developer-tools",
    "skills",
    "skill-graph",
    "symlinks",
    "terminal-ui",
    "repo-local",
    "codex",
    "claude-code",
    "claude",
    "gemini-cli",
    "cursor",
    "cli"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

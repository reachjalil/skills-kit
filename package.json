{
  "name": "skills-kit",
  "private": true,
  "type": "module",
  "version": "1.0.2",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm --filter @skills-kit/cli run build",
    "check": "pnpm --filter @skills-kit/cli run check",
    "check:fast": "pnpm --filter @skills-kit/cli run check:fast",
    "dev": "pnpm --filter @skills-kit/cli run dev",
    "lint": "biome check packages",
    "lint:fix": "biome check --write packages",
    "test": "pnpm --filter @skills-kit/cli run test",
    "quality": "pnpm --filter @skills-kit/cli run quality",
    "publish:dry-run": "pnpm --filter @skills-kit/cli run publish:dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
